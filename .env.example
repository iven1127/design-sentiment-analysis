# 数据库配置
DATABASE_URL=sqlite:///xhs_sentiment.db
DATABASE_ECHO=false

# API配置
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_LOG_LEVEL=info

# Web配置
WEB_PORT=8501
WEB_THEME=light

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=logs

# 爬虫配置
CRAWLER_HEADLESS=true
CRAWLER_MAX_RETRIES=3

# 情感分析配置
SENTIMENT_MODEL=uer/roberta-base-finetuned-dianping-chinese
SENTIMENT_BATCH_SIZE=8

# 任务配置
TASK_MAX_CONCURRENT=5
